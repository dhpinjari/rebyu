<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Product Review Form</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      /* Custom styles for the star rating */
      .star-rating input[type="radio"] {
        display: none;
      }
      .star-rating label {
        font-size: 2.5rem; /* Larger stars */
        color: #4a5568; /* Default star color (gray-600 equivalent) */
        cursor: pointer;
        transition: color 0.2s ease-in-out;
      }
      .star-rating label:hover,
      .star-rating label:hover ~ label,
      .star-rating input[type="radio"]:checked ~ label {
        color: #fbd38d; /* Yellow-300 equivalent for active/hover */
      }
      /* Ensure Inter font is used */
      body {
        font-family: "Inter", sans-serif;
      }
    </style>
  </head>
  <body
    class="bg-gray-900 text-white min-h-screen flex items-center justify-center p-4"
  >
    <div
      class="bg-gray-800 p-8 rounded-lg shadow-lg max-w-2xl w-full border border-gray-700"
    >
      <h2 class="text-3xl font-bold text-center mb-6 text-yellow-300">
        Submit Your Review
      </h2>
      <form id="reviewForm" action="/reviewsubmit" method="post">
        <!-- Product Rating -->
        <div class="mb-6">
          <label
            for="reviewRating"
            class="block text-gray-300 text-sm font-medium mb-2"
            >Rating</label
          >
          <div class="flex flex-row-reverse justify-end star-rating">
            <input
              type="radio"
              id="star5"
              name="reviewRating"
              value="5"
              class="hidden"
            />
            <label for="star5" title="5 stars">&#9733;</label>
            <input
              type="radio"
              id="star4"
              name="reviewRating"
              value="4"
              class="hidden"
            />
            <label for="star4" title="4 stars">&#9733;</label>
            <input
              type="radio"
              id="star3"
              name="reviewRating"
              value="3"
              class="hidden"
            />
            <label for="star3" title="3 stars">&#9733;</label>
            <input
              type="radio"
              id="star2"
              name="reviewRating"
              value="2"
              class="hidden"
            />
            <label for="star2" title="2 stars">&#9733;</label>
            <input
              type="radio"
              id="star1"
              name="reviewRating"
              value="1"
              class="hidden"
            />
            <label for="star1" title="1 star">&#9733;</label>
          </div>
        </div>

        <!-- Review Title -->
        <div class="mb-4">
          <label
            for="reviewTitle"
            class="block text-gray-300 text-sm font-medium mb-2"
            >Review Title</label
          >
          <input
            type="text"
            id="reviewTitle"
            name="reviewTitle"
            class="w-full px-4 py-2 rounded-md bg-gray-700 border border-gray-600 focus:border-yellow-500 focus:ring focus:ring-yellow-500 focus:ring-opacity-50 text-white placeholder-gray-400"
            placeholder="e.g., 'Amazing product, highly recommend!'"
            required
          />
        </div>

        <!-- Review Description -->
        <div class="mb-4">
          <label
            for="reviewDesc"
            class="block text-gray-300 text-sm font-medium mb-2"
            >Description</label
          >
          <textarea
            id="reviewDesc"
            name="reviewDesc"
            rows="5"
            class="w-full px-4 py-2 rounded-md bg-gray-700 border border-gray-600 focus:border-yellow-500 focus:ring focus:ring-yellow-500 focus:ring-opacity-50 text-white placeholder-gray-400 resize-y"
            placeholder="Share your detailed experience with the product..."
            required
          ></textarea>
        </div>

        <!-- Image Link Option -->
        <div class="mb-6">
          <label
            for="reviewImage"
            class="block text-gray-300 text-sm font-medium mb-2"
            >Image Link (Optional)</label
          >
          <input
            type="url"
            id="reviewImage"
            name="reviewImage"
            class="w-full px-4 py-2 rounded-md bg-gray-700 border border-gray-600 focus:border-yellow-500 focus:ring focus:ring-yellow-500 focus:ring-opacity-50 text-white placeholder-gray-400"
            placeholder="e.g., https://example.com/product-image.jpg"
          />
        </div>
        <!-- Submit Button -->

        <div class="flex gap-1">
          <button
            type="submit"
            class="w-full bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-3 px-4 rounded-md focus:outline-none focus:shadow-outline transition duration-300 ease-in-out transform hover:scale-105"
          >
            Submit Review
          </button>
          <a
            href="/customerReviews"
            id="cancelButton"
            class="w-full px-6 py-3 font-semibold text-yellow-700 bg-gray-200 rounded-lg shadow-md hover:bg-gray-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-700 transition duration-200 text-center"
          >
            Cancel
          </a>
        </div>
      </form>
    </div>
  </body>
</html>
