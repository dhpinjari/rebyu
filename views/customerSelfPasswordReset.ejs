<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Password Reset</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Font (Inter) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Inter", sans-serif;
      }
    </style>
  </head>
  <body class="bg-gray-900 flex items-center justify-center min-h-screen p-4">
    <!-- Main Container for the Form -->
    <div
      class="bg-gray-800 p-8 md:p-12 rounded-2xl shadow-2xl w-full max-w-md border border-gray-700"
    >
      <!-- Form Header -->
      <h2 class="text-white text-3xl md:text-4xl font-bold text-center mb-2">
        Reset Your Password
      </h2>
      <p class="text-gray-400 text-center text-sm md:text-base mb-8">
        Please enter your new password below.
      </p>

      <!-- The Password Reset Form -->
      <form
        id="passwordResetForm"
        class="space-y-6"
        action="/customerreviews/customerSelfPasswordReset/<%= customerSelfPasswordUpdate._id %>"
        method="POST"
      >
        <!-- Email Address Input (Non-editable) -->
        <div>
          <label for="email" class="block text-sm font-medium text-gray-300"
            >Email Address</label
          >
          <div class="mt-1">
            <input
              id="email"
              name="email"
              type="text"
              value="<%= customerSelfPasswordUpdate.email %>"
              readonly
              class="appearance-none block w-full px-4 py-3 border border-gray-600 rounded-lg shadow-sm placeholder-gray-500 focus:outline-none sm:text-sm bg-gray-700 text-gray-400 cursor-not-allowed transition-colors duration-200"
            />
          </div>
        </div>
        <!-- Old Password Input -->
        <div>
          <label
            for="oldPassword"
            class="block text-sm font-medium text-gray-300"
            >Old Password</label
          >
          <div class="mt-1">
            <input
              id="oldPassword"
              name="oldPassword"
              type="password"
              required
              class="appearance-none block w-full px-4 py-3 border border-gray-600 rounded-lg shadow-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm bg-gray-700 text-white transition-colors duration-200"
              placeholder="Enter your new password"
              minlength="8"
            />
          </div>
        </div>
        <!-- New Password Input -->
        <div>
          <label
            for="newPassword"
            class="block text-sm font-medium text-gray-300"
            >New Password</label
          >
          <div class="mt-1">
            <input
              id="newPassword"
              name="newPassword"
              type="password"
              required
              class="appearance-none block w-full px-4 py-3 border border-gray-600 rounded-lg shadow-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm bg-gray-700 text-white transition-colors duration-200"
              placeholder="Enter your new password"
              minlength="8"
            />
          </div>
        </div>

        <!-- Confirm Password Input -->
        <!-- <div>
          <label
            for="confirmPassword"
            class="block text-sm font-medium text-gray-300"
            >Confirm Password</label
          >
          <div class="mt-1">
            <input
              id="confirmPassword"
              name="confirmPassword"
              type="password"
              required
              class="appearance-none block w-full px-4 py-3 border border-gray-600 rounded-lg shadow-sm placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm bg-gray-700 text-white transition-colors duration-200"
              placeholder="Confirm your new password"
            />
          </div>
        </div> -->

        <!-- Submit Button -->
        <div>
          <button
            type="submit"
            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200"
          >
            Reset Password
          </button>
        </div>
      </form>
    </div>
  </body>
</html>
