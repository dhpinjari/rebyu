<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Reviews Panel</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap");
      body {
        font-family: "Inter", sans-serif;
      }
    </style>
  </head>
  <body class="bg-gray-900 text-gray-200 min-h-screen p-6 sm:p-8">
    <!-- Main Container -->
    <div class="max-w-full mx-auto py-12">
      <!-- Header -->

      <header class="text-center mb-12">
        <div><%= currentAdmin.firstName %> <%= currentAdmin.lastName %></div>

        <div class="absolute right-0 group mt-2 mr-5">
          <button
            class="p-2 rounded-full bg-gray-800 hover:bg-gray-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
          >
            <img
              src="<%= currentAdmin.profileImage %>"
              alt="dp"
              class="w-12 h-12 rounded-full border-2 border-blue-400"
            />
          </button>

          <div
            class="absolute right-0 mt-2 w-48 bg-gray-800 rounded-md shadow-lg py-2 z-10 opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-200 ease-in-out"
          >
            <a
              href="/customerlist"
              class="block text-left px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors"
              >Manage Customer</a
            >

            <a
              href="/adminReviews"
              class="block text-left px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors"
              >Manage Customer Reviews</a
            >

            <a
              href="#"
              class="block text-left px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors"
              >Edit Details</a
            >
            <a
              href="#"
              class="block text-left px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 hover:text-white transition-colors"
              >Reset Password</a
            >
          </div>
        </div>
        <h1
          class="text-4xl sm:text-5xl font-extrabold tracking-tight text-white mb-4"
        >
          Customer Reviews
        </h1>
        <p class="text-lg text-gray-400">
          Manage and moderate all customer feedback in one place.
        </p>
        <button
          class="flex items-center space-x-2 text-gray-400 hover:text-red-500 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
            />
          </svg>
          <a href="/logout" rel="noopener noreferrer"
            ><span class="font-medium">Logout</span></a
          >
        </button>
      </header>

      <!-- Search Bar -->
      <div class="mb-8">
        <input
          type="text"
          placeholder="Search reviews..."
          class="w-full p-4 rounded-xl bg-gray-800 text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors"
        />
      </div>
      <% if(showAdminReviews.length > 0) { %>
      <!-- Reviews List -->
      <% showAdminReviews.forEach(review => { %>
      <div class="space-y-6">
        <!-- Review Card 1 -->
        <div
          class="bg-gray-800 rounded-2xl shadow-lg p-6 flex flex-col sm:flex-row sm:items-center justify-between transition-colors hover:bg-gray-700"
        >
          <!-- Review Content Section -->
          <div class="flex-1 mb-4 sm:mb-0">
            <div
              class="flex text-yellow-400 text-2xl pt-0 pr-0 pb-[10px] pl-[10px]"
            >
              <!-- Star Icons -->
              <!-- Filled Stars -->
              <% for (let i = 0; i < review.reviewRating; i++) { %> &#9733; <% }
              %>
              <!-- Empty Stars -->
              <% for (let i = 0; i < 5 - review.reviewRating; i++) { %> &#9734;
              <% } %>
            </div>
            <!-- Reviewer Info & Image -->
            <div class="flex items-center justify-between mb-4 w-[95%]">
              <div class="flex items-center">
                <img
                  src="<%= review.customerID.profileImage %>"
                  alt="Reviewer Avatar"
                  class="w-12 h-12 rounded-full mr-4 object-cover border-2 border-gray-600"
                />
                <div>
                  <h2 class="text-xl font-semibold text-white">
                    <%= review.customerID.firstName %> <%=
                    review.customerID.lastName %>
                  </h2>
                  <span class="text-sm text-gray-400"
                    ><%= review.customerID.email %></span
                  >
                </div>
              </div>
              <p class="text-sm text-gray-400">
                <%= review.date.getDate().toString().padStart(2, '0') %>-<%=
                (review.date.getMonth()+1).toString().padStart(2, '0') %>-<%=
                review.date.getFullYear() %>
              </p>
            </div>

            <!-- Review Title & Body -->
            <h3 class="text-xl font-bold text-blue-400 mb-2">
              "<%= review.reviewTitle %>"
            </h3>
            <p class="text-gray-300 leading-relaxed">
              <%= review.reviewDesc %>
            </p>
            <div class="flex items-center mt-4">
              <img
                src="<%= review.reviewImage %>"
                alt="Customer submitted image"
                class="max-w-[6%]"
              />
            </div>
          </div>

          <!-- Admin Actions -->
          <div
            class="flex-shrink-0 flex justify-start sm:justify-end space-x-3 mt-4 sm:mt-0"
          >
            <button
              class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors"
            >
              <a href="/adminReviews/adminEditReview/<%= review._id %>">
                Edit</a
              >
            </button>
            <button
              class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-lg transition-colors"
            >
              <a href="/adminReviews/adminDeleteReview/<%= review._id %>">
                Delete</a
              >
            </button>
          </div>
        </div>
        <% }) %>
        <!-- Loop Ends Here -->

        <% } else { %>
        <h2>No customer submitted reviews yet</h2>
        <% } %>
      </div>
    </div>
  </body>
</html>
